{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:ngrok": "node ../../scripts/configure-ngrok-env.mjs && next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "e2e": "playwright test --headed",
    "e2e:modules": "playwright test e2e/modules --project=chromium",
    "e2e:modules:cross-browser": "cross-env E2E_CROSS_BROWSER=true playwright test e2e/modules",
    "e2e:debug": "playwright test --headed --workers=1 --project=chromium",
    "e2e:matrix": "node scripts/generate-e2e-matrix.mjs",
    "e2e:scaffold": "node scripts/generate-playwright-specs.mjs",
    "e2e:ci": "playwright test --project=chromium",
    "e2e:ci:critical": "playwright test --project=chromium --grep @p0",
    "e2e:cross-browser": "cross-env E2E_CROSS_BROWSER=true playwright test",
    "e2e:report": "playwright show-report",
    "e2e:coverage": "node scripts/e2e-coverage-report.mjs",
    "env:ngrok": "node ../../scripts/configure-ngrok-env.mjs",
    "visual:test": "playwright test e2e/visual-regression.spec.ts --project=chromium",
    "bundle:analyze": "cross-env ANALYZE=true next build",
    "lighthouse:demo": "lighthouse http://localhost:3000/demo --only-categories=performance,accessibility --preset=desktop --chrome-flags=\"--headless\" --output=json --output-path=./.lighthouse-demo.json",
    "lighthouse:login": "lighthouse http://localhost:3000/login --only-categories=performance,accessibility --preset=desktop --chrome-flags=\"--headless\" --output=json --output-path=./.lighthouse-login.json"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "@mui/x-date-pickers": "^7.29.4",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.1.0",
    "@twilio/voice-sdk": "^2.18.3",
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.20",
    "mui-datatables": "^4.3.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.3",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "lighthouse": "^12.8.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
