# Global ignores - these should always be ignored
.DS_Store
Thumbs.db
*.zip
*.7z
*.tar
*.tar.gz
*.md
*.ps1

# Ignore everything by default
*

# Exception: Include the apps folder
!apps/
!apps/**

# Keep .gitignore itself
!.gitignore

# Ignore specific build artifacts and logs inside apps
apps/api/vendor/
apps/api/public/build/
apps/api/public/hot
apps/api/public/storage
apps/api/storage/logs/
apps/api/storage/*.key
apps/api/storage/pail/

apps/web/.next/
apps/web/docs/
apps/web/out/
apps/web/build/
apps/web/coverage/
apps/web/playwright-report/
apps/web/test-results/

# Ignore environment and sensitive files everywhere
**/.env
**/.env.*
**/*.log
**/node_modules/
**/.claude/
**/.md

# Ignore test directories and script files
apps/api/tests/
apps/web/e2e/
apps/api/test_meta_payload.php
apps/web/scripts/test-how-to-use-cross-browser.mjs

